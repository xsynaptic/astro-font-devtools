{
	"name": "astro-font-devtools",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for the @xsynaptic/astro-font-devtools package and its playground",
	"author": "Alexander Synaptic <alexander@synapticism.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xsynaptic/astro-font-devtools.git"
	},
	"type": "module",
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"build": "pnpm --filter './packages/*' build",
		"playground": "pnpm --filter playground dev",
		"lint": "eslint . --max-warnings=0",
		"check-types": "tsc -p tsconfig.json && pnpm -r check-types",
		"fix": "prettier --write . && eslint . --fix && pnpm check-types && knip",
		"check": "prettier --check . && eslint . --max-warnings=0 && pnpm check-types && knip",
		"test": "vitest run",
		"test:e2e": "pnpm -r --if-present test:e2e",
		"release": "pnpm check && pnpm --filter './packages/*' build && pnpm test && pnpm test:e2e && changeset publish",
		"postrelease": "git push --follow-tags origin main"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/node": "^22.19.21",
		"@xsynaptic/eslint-config": "^3.8.0",
		"eslint": "^9.39.4",
		"jiti": "^2.7.0",
		"knip": "^6.16.1",
		"prettier": "^3.8.4",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8"
	}
}
