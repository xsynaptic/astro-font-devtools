{
	"name": "@xsynaptic/astro-font-devtools",
	"version": "0.0.3",
	"description": "An Astro dev toolbar plugin for previewing fonts from Google, Fontsource, Bunny, and Fontshare live on your site.",
	"keywords": [
		"astro",
		"astro-integration",
		"withastro",
		"dev-toolbar",
		"fonts",
		"web-fonts",
		"google-fonts",
		"fontsource"
	],
	"homepage": "https://github.com/xsynaptic/astro-font-devtools#readme",
	"bugs": "https://github.com/xsynaptic/astro-font-devtools/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xsynaptic/astro-font-devtools.git"
	},
	"license": "MIT",
	"author": "Alexander Synaptic <x@spectralcodex.com>",
	"type": "module",
	"engines": {
		"node": ">=22.12.0"
	},
	"exports": {
		".": {
			"types": "./dist/integration.d.mts",
			"import": "./dist/integration.mjs"
		}
	},
	"main": "./dist/integration.mjs",
	"types": "./dist/integration.d.mts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"playground": "pnpm --filter playground dev",
		"check": "tsc --noEmit",
		"format": "prettier --write . && eslint . --fix && tsc --noEmit && knip",
		"knip": "knip",
		"lint": "eslint . --max-warnings=0",
		"test": "vitest run",
		"prepublishOnly": "pnpm lint && pnpm check && pnpm test && pnpm knip && pnpm build"
	},
	"dependencies": {
		"unifont": "^0.7.4",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"astro": "^6.3.8"
	},
	"devDependencies": {
		"@eslint/config-helpers": "^0.6.0",
		"@eslint/js": "^9.39.4",
		"@stylistic/eslint-plugin": "^6.0.0-beta.4",
		"@types/node": "^22.0.0",
		"astro": "^6.3.8",
		"eslint": "^9.39.4",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^17.6.0",
		"knip": "^6.14.2",
		"prettier": "^3.8.3",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^7.3.3",
		"vitest": "^4.1.7"
	}
}
